# ============================================
# SYRAX — root .gitignore (monorepo)
# ============================================

# --- Secrets / environment ---
.env
.env.local
.env.*.local
*.env

# --- Python / Django (backend/) ---
__pycache__/
*.py[cod]
*$py.class
*.so
venv/
.venv/
env/
*.sqlite3
backend/staticfiles/
backend/media/

# --- Node / Next.js / Vite (web/ and admin/) ---
node_modules/
dist/
build/
.next/
out/
.vite/
*.tsbuildinfo
next-env.d.ts
.npm
.yarn/
yarn-error.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# --- Editors / IDE ---
.vscode/
.idea/
*.swp
*.swo
*.iml

# --- OS junk ---
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# --- Claude Code (local state) ---
.claude/

# --- Logs ---
*.log
logs/

# --- Coverage / tests ---
coverage/
.coverage
htmlcov/
.pytest_cache/
.tox/
